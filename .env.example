# ============================================================
#  IBM watsonx.ai — Fitness Buddy Agent Configuration
# ============================================================

# IBM Cloud API Key  (IAM → Manage → API keys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID  (watsonx.ai → Projects → your project → Manage → General)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai Endpoint URL  (choose the region closest to you)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite Model ID  (recommended: ibm/granite-13b-instruct-v2 or ibm/granite-3-8b-instruct)
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# Flask Secret Key  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_super_secret_flask_key_change_this_in_production

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///instance/fitness_buddy.db

# App Settings
APP_NAME=Fitness Buddy AI
APP_VERSION=1.0.0
MAX_CHAT_HISTORY=20
